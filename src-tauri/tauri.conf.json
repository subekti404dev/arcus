{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arcus",
  "version": "0.1.0",
  "identifier": "com.urip.arcus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Arcus",
        "decorations": false,
        "width": 1280,
        "height": 820,
        "minWidth": 360,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
